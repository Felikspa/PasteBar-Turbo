{
  "build": {
    "beforeBuildCommand": "cd ./packages/pastebar-app-ui && npm run build",
    "distDir": "../packages/pastebar-app-ui/dist-ui/"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "AnotherVision LLC",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "app.anothervision.pasteBar",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null
      },
      "resources": [],
      "shortDescription": "Limitless Clipboard Manager",
      "targets": ["appimage", "nsis", "app", "dmg"],
      "windows": {
        "nsis": {
          "installerIcon": "./icons/icon.ico"
        },
        "webviewInstallMode": {
          "type": "embedBootstrapper"
        }
      }
    }
  }
}
